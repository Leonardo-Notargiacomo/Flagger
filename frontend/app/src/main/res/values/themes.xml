<resources xmlns:tools="http://schemas.android.com/tools">
    <!-- Base application theme. -->
    <style name="Theme.Frontend" parent="Theme.MaterialComponents.DayNight.DarkActionBar">
        <!-- Primary brand color - Explorer Orange -->
        <item name="colorPrimary">@color/explorer_orange</item>
        <item name="colorPrimaryVariant">@color/explorer_brown</item>
        <item name="colorOnPrimary">@color/white</item>
        <!-- Secondary brand color. -->
        <item name="colorSecondary">@color/teal_200</item>
        <item name="colorSecondaryVariant">@color/teal_700</item>
        <item name="colorOnSecondary">@color/black</item>
        <!-- Status bar color - Explorer Cream -->
        <item name="android:statusBarColor">@color/explorer_cream</item>
        <!-- Window background - Explorer Cream -->
        <item name="android:windowBackground">@color/explorer_cream</item>
    </style>

    <!-- Splash Screen Theme -->
    <style name="Theme.Frontend.Splash" parent="Theme.SplashScreen">
        <item name="windowSplashScreenBackground">@color/explorer_cream</item>
        <item name="windowSplashScreenAnimatedIcon">@mipmap/ic_launcher</item>
        <item name="postSplashScreenTheme">@style/Theme.AppCompat.Light.NoActionBar</item>
    </style>
</resources>